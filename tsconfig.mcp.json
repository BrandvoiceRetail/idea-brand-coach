{
  "//": "Dedicated type-check for the Node MCP host (src/mcp). Kept separate from the SPA's bundler-resolution config. Run: npx tsc -p tsconfig.mcp.json --noEmit",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/mcp/**/*.ts"]
}
