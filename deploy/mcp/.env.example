# Brand-Coach MCP gateway — server-side env.
# Copy to `.env` on the box:  cp .env.example .env
# (.env is gitignored — never commit real secrets. The Supabase anon key below is a
#  PUBLIC read-only key — the same one shipped in the SPA bundle — so it is safe here.)

MCP_PORT=8787

# Supabase project for JWT verification (auth.getUser). Set explicitly in prod.
SUPABASE_URL=https://ecdrxtbclxfpkknasmrw.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVjZHJ4dGJjbHhmcGtrbmFzbXJ3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTM5ODE5ODYsImV4cCI6MjA2OTU1Nzk4Nn0.yPlOSq4l4PMD9RlchTBeXs5EBmzggGQGp7A8B3qGAAk

# Optional — IV-OS Marketing MCP (asset/ledger reads). Leave unset for Alpha;
# ledger reads degrade gracefully (available:false) when absent.
# IVOS_MCP_URL=
# IVOS_MCP_TOKEN=

# Optional — analytics. No-op if unset.
# POSTHOG_API_KEY=
# POSTHOG_HOST=

# OAuth 2.1 (MCP authorization; Supabase Auth is the authorization server).
# Canonical public URL of this resource — must match the connector URL users enter.
MCP_PUBLIC_URL=https://ideabrandcoach.com/mcp
# Enforcement kill switch: true => unauthenticated /mcp gets 401 + WWW-Authenticate
# (the trigger that starts the OAuth flow). false => serve anonymously (metadata still
# advertised). Flip without a rebuild.
MCP_OAUTH_REQUIRE_AUTH=true
# Scope advertised to clients. `email` is deliberate: `openid` triggers OIDC ID-token
# generation, which 500s on this project (no asymmetric JWT signing key / empty JWKS).
# MCP_OAUTH_SCOPE=email
#
# Supabase-side setup (Management API or dashboard, NOT in this file):
#   config/auth: oauth_server_enabled=true, oauth_server_allow_dynamic_registration=true,
#                oauth_server_authorization_path=/oauth/consent,
#                uri_allow_list += https://claude.ai/api/mcp/auth_callback
#   Caddy: route /.well-known/oauth-protected-resource* -> brand-coach-mcp:8787
# See docs/integrations/MCP_OAUTH.md.

# Service-role key — REQUIRED for the coach_instructions substrate (Phase B):
# the gateway reads published instruction rows with this at boot/session start.
# Without it the read falls back to the anon client, RLS blocks it, and the
# substrate silently no-ops (fail-open to the inline prompts).
SUPABASE_SERVICE_ROLE_KEY=
