# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Deployment Configuration
# P0 = Beta Launch (current), P1 = Enhanced Collaboration, P2 = Advanced Analytics
VITE_DEPLOYMENT_PHASE=P0

# Beta Features
# Enable/disable the floating beta feedback widget
# Set to 'true' during beta, 'false' to hide after beta launch
VITE_ENABLE_BETA_FEEDBACK=true

# OpenAI Configuration (for AI features)
# Note: These are handled server-side in Supabase Edge Functions
# OPENAI_API_KEY is set in Supabase Dashboard > Edge Functions > Secrets

# Figma Integration (server-side secrets — set via `npx supabase secrets set`, NOT in the frontend)
# Create a Figma OAuth app at https://www.figma.com/developers/apps and register the redirect URL
# <origin>/integrations/figma/callback for each environment. See docs/FIGMA_INTEGRATION.md.
#   FIGMA_CLIENT_ID=...                  # required
#   FIGMA_CLIENT_SECRET=...              # required
#   FIGMA_TOKEN_ENC_KEY=...              # base64 32-byte key (openssl rand -base64 32); required in prod
#   FIGMA_OAUTH_SCOPE=files:read         # optional (default files:read)
#   FIGMA_STATE_TTL_SECONDS=600          # optional (default 600)
#   FIGMA_ALLOWED_ORIGINS=...            # optional, comma-separated OAuth redirect origin allow-list

# PostHog (Alpha instrumentation — funnel events + exception capture)
# Unset = analytics disabled (all capture calls safely no-op).
# Key from PostHog Cloud > Project Settings. Host defaults to https://us.i.posthog.com.
# VITE_POSTHOG_KEY=phc_your_project_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional: Analytics and Tracking
# VITE_GA_MEASUREMENT_ID=your_google_analytics_id
# VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Optional: Feature Flags
# VITE_ENABLE_ONBOARDING_TOUR=true
# VITE_ENABLE_SYSTEM_KB=true
# Gates the Settings → Integrations (Figma) UI. Leave unset in prod until the
# Figma OAuth app + FIGMA_* secrets are configured, then set to 'true' and rebuild.
# VITE_ENABLE_FIGMA=true

# Canva Connect integration
# These are SERVER-SIDE Supabase Edge Function secrets, NOT client (VITE_) vars.
# The browser never sees them — set them with `supabase secrets set ...` (or in
# the Supabase Dashboard > Edge Functions > Secrets). In particular, the client
# secret must NEVER be exposed to the frontend.
#   CANVA_CLIENT_ID              - Canva app client id
#   CANVA_CLIENT_SECRET          - Canva app client secret (server-side only)
#   CANVA_REDIRECT_URI           - public URL of the canva-oauth-callback function,
#                                  registered as a redirect URL in the Canva app
#   CANVA_ALLOWED_RETURN_ORIGINS - comma-separated allowlist of app origins
#                                  permitted as post-callback redirect targets
