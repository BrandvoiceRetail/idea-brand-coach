{
  "_description": "Base Claude Code settings for IDEA Brand Coach. Hooks come from the shared best-practices guide (synced into .claude/hooks/ via `bpg-sync --project . --only hooks --mode copy`). Profile-specific overrides go in settings.local.json.",
  "_source": "agentic-tooling/settings/settings.base.json in @matthewkerns/software-development-best-practices-guide",

  "permissions": {
    "allow": [
      "Skill",
      "Bash",
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(sudo rm -rf *)",
      "Bash(dd if=/dev/zero of=/dev/*)",
      "Bash(mkfs *)",
      "Bash(> /dev/sda*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/statusline.sh",
    "padding": 0
  },

  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "MAX_THINKING_TOKENS": "16000"
  }
}
